<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>La Question Final...</title>
    <style>
        body {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            background-color: #ffebee;
            font-family: 'Arial', sans-serif;
            overflow: hidden;
            touch-action: manipulation;
        }
        .container {
            text-align: center;
            background: white;
            padding: 40px 20px;
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            width: 85%;
            max-width: 400px;
        }
        .btns { display: flex; justify-content: center; align-items: center; gap: 20px; margin-top: 20px; }
        button { padding: 15px 25px; border-radius: 50px; border: none; cursor: pointer; font-weight: bold; transition: 0.2s; }
        #btn-oui { background: #4caf50; color: white; font-size: 18px; }
        #btn-non { background: #f44336; color: white; position: fixed; font-size: 18px; z-index: 1000; }
    </style>
</head>
<body>
    <div class="container">
        <h1 id="question"> Suis-je le meilleur besti du monde ? </h1>
        <div class="btns">
            <button id="btn-oui">OUI</button>
            <button id="btn-non">NON</button>
        </div>
    </div>

    <script>
        const btnNon = document.getElementById('btn-non');
        const btnOui = document.getElementById('btn-oui');
        let size = 18;

        function moveButton() {
            const x = Math.random() * (window.innerWidth - btnNon.offsetWidth - 20);
            const y = Math.random() * (window.innerHeight - btnNon.offsetHeight - 20);
            btnNon.style.left = x + 'px';
            btnNon.style.top = y + 'px';
            
            size += 10;
            btnOui.style.fontSize = size + 'px';
            btnOui.style.padding = (size/1.5) + 'px ' + (size) + 'px';
        }

        btnNon.addEventListener('mouseover', moveButton);
        btnNon.addEventListener('touchstart', (e) => { e.preventDefault(); moveButton(); });

        btnOui.addEventListener('click', () => {
            document.body.innerHTML = "<div class='container'><h1>Je savais ! <br> ma Bestie! Tu es troooop fan ! </h1></div>";
        });
    </script>
</body>
</html>
